    "This permanently deletes the playlist from your server. This action cannot be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies löscht die Playlist dauerhaft vom Server. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό διαγράφει οριστικά τη λίστα από τον διακομιστή σας. Αυτή η ενέργεια δεν μπορεί να αναιρεθεί."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina permanentemente la lista de tu servidor. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime définitivement la liste de lecture de votre serveur. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo elimina definitivamente la playlist dal tuo server. Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレイリストをサーバから完全に削除します。この操作は取り消せません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从你的服务器上永久删除该播放列表。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會永久從你的伺服器刪除此播放列表。此操作無法復原。"
          }
        }
      }
    },
    "This playlist doesn't have any tracks yet.": {
