        }
      }
    },
    "Albums and playlists you download will be available here, even offline.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heruntergeladene Alben und Playlists sind hier verfügbar, auch offline."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα άλμπουμ και οι λίστες που λαμβάνετε θα είναι διαθέσιμα εδώ, ακόμη και εκτός σύνδεσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los álbumes y listas que descargues estarán disponibles aquí, incluso sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les albums et listes de lecture que vous téléchargez seront disponibles ici, même hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli album e le playlist che scarichi saranno disponibili qui, anche offline."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードしたアルバムとプレイリストは、オフラインでもここで利用できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你下载的专辑和播放列表将显示在此处，离线时也可使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你下載的專輯和播放列表會在這裡提供，即使離線也能使用。"
          }
        }
      }
    },
