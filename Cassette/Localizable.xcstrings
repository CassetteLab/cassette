    "If your server already relays listens to ListenBrainz, leave this disabled to avoid duplicate scrobbles.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn der Server Wiedergaben bereits an ListenBrainz weiterleitet, dies deaktiviert lassen, um doppelte Scrobbles zu vermeiden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αν ο διακομιστής σας μεταβιβάζει ήδη τις ακροάσεις στο ListenBrainz, αφήστε το απενεργοποιημένο για να αποφύγετε διπλά scrobbles."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu servidor ya envía las escuchas a ListenBrainz, deja esto desactivado para evitar scrobbles duplicados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si votre serveur transmet déjà vos écoutes à ListenBrainz, laissez cette option désactivée pour éviter les doublons."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il tuo server invia già gli ascolti a ListenBrainz, lascia questa opzione disattivata per evitare scrobble duplicati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバがすでにListenBrainzに再生履歴を送信している場合は、重複したスクロブルを避けるためこれを無効のままにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你的服务器已将收听记录转发到 ListenBrainz，请将此项保持禁用以避免重复 scrobble。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你的伺服器已經將聆聽記錄轉送到 ListenBrainz，請保持停用以避免重複記錄。"
          }
        }
      }
    },
