          "stringUnit": {
            "state": "translated",
            "value": "請嘗試不同的搜尋字詞。"
          }
        }
      }
    },
    "Try again or skip to another track.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut versuchen oder zu einem anderen Titel springen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δοκιμάστε ξανά ή μεταβείτε σε άλλο κομμάτι."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inténtalo de nuevo o salta a otra pista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réessayez ou passez à une autre piste."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riprova o passa a un altro brano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "もう一度試すか、別のトラックにスキップしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请重试或跳到其他曲目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請再試一次，或跳至另一首曲目。"
          }
        }
      }
    },
