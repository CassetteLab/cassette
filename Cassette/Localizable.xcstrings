    "No downloaded music available. Download albums or playlists while online to listen offline.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine heruntergeladene Musik verfügbar. Alben oder Playlists online herunterladen, um offline zu hören."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχει διαθέσιμη ληφθείσα μουσική. Λάβετε άλμπουμ ή λίστες ενώ είστε συνδεδεμένοι για να τα ακούτε εκτός σύνδεσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay música descargada. Descarga álbumes o listas con conexión para escucharlos sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune musique téléchargée disponible. Téléchargez des albums ou listes de lecture en ligne pour les écouter hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna musica scaricata disponibile. Scarica album o playlist quando sei online per ascoltarli offline."
          }
