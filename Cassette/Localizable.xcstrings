    "The audio files will be deleted from this device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Audiodateien werden von diesem Gerät gelöscht."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα αρχεία ήχου θα διαγραφούν από αυτήν τη συσκευή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los archivos de audio se eliminarán de este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fichiers audio seront supprimés de cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I file audio verranno eliminati da questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オーディオファイルはこのデバイスから削除されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音频文件将从此设备中删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "音訊檔案將從此裝置刪除。"
          }
        }
      }
    },
    "The hostname could not be resolved. Check the URL, DNS settings, and local network access in iOS Settings › Privacy › Local Network.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Hostname konnte nicht aufgelöst werden. URL, DNS-Einstellungen und lokalen Netzwerkzugriff in iOS Einstellungen › Datenschutz › Lokales Netzwerk prüfen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν ήταν δυνατή η ανάλυση του ονόματος κεντρικού υπολογιστή. Ελέγξτε το URL, τις ρυθμίσεις DNS και την πρόσβαση στο τοπικό δίκτυο στο iOS Ρυθμίσεις › Απόρρητο › Τοπικό δίκτυο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo resolver el nombre de host. Comprueba la URL, los ajustes de DNS y el acceso a la red local en Ajustes de iOS › Privacidad › Red local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom d'hôte n'a pas pu être résolu. Vérifiez l'URL, les réglages DNS et l'accès au réseau local dans Réglages iOS › Confidentialité › Réseau local."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile risolvere l'hostname. Controlla l'URL, le impostazioni DNS e l'accesso alla rete locale in Impostazioni iOS › Privacy › Rete locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホスト名を解決できませんでした。URL、DNS設定、およびiOSの設定 › プライバシー › ローカルネットワークでのローカルネットワークアクセスを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解析主机名。请检查 URL、DNS 设置以及 iOS 设置 › 隐私 › 本地网络 中的本地网络访问权限。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法解析主機名稱。請檢查 URL、DNS 設定，以及 iOS「設定」›「隱私權」›「區域網路」中的區域網路存取權限。"
          }
        }
      }
    },
    "The operation timed out. Please check your connection and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeitüberschreitung des Vorgangs. Bitte Verbindung prüfen und erneut versuchen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η λειτουργία έληξε λόγω χρονικού ορίου. Ελέγξτε τη σύνδεσή σας και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se agotó el tiempo de la operación. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'opération a expiré. Vérifiez votre connexion et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'operazione è scaduta. Controlla la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "操作がタイムアウトしました。接続を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作超时。请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "操作已逾時。請檢查你的連線後再試一次。"
          }
        }
      }
    },
    "The server did not respond as a Subsonic/Navidrome server. Check the URL.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat nicht als Subsonic/Navidrome-Server geantwortet. URL prüfen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής δεν απάντησε ως διακομιστής Subsonic/Navidrome. Ελέγξτε το URL."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor no respondió como un servidor Subsonic/Navidrome. Comprueba la URL."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur n'a pas répondu comme un serveur Subsonic/Navidrome. Vérifiez l'URL."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server non ha risposto come un server Subsonic/Navidrome. Controlla l'URL."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバがSubsonic/Navidromeサーバとして応答しませんでした。URLを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器未以 Subsonic/Navidrome 服务器的方式响应。请检查 URL。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器沒有以 Subsonic/Navidrome 伺服器的方式回應。請檢查 URL。"
          }
        }
      }
    },
    "The server is not accepting connections. Check the port and whether your server is running.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server nimmt keine Verbindungen an. Port prüfen und ob der Server läuft."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής δεν δέχεται συνδέσεις. Ελέγξτε τη θύρα και αν ο διακομιστής σας λειτουργεί."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor no acepta conexiones. Comprueba el puerto y si tu servidor está en marcha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur n'accepte pas les connexions. Vérifiez le port et si votre serveur est en marche."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server non accetta connessioni. Controlla la porta e se il tuo server è in esecuzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバが接続を受け付けていません。ポートとサーバが起動しているかを確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器未接受连接。请检查端口以及你的服务器是否正在运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器未接受連線。請檢查連接埠以及你的伺服器是否正在運作。"
          }
        }
      }
    },
    "The server redirected to a different domain. Check your server configuration.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat auf eine andere Domain weitergeleitet. Server-Konfiguration prüfen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής ανακατεύθυνε σε διαφορετικό τομέα. Ελέγξτε τη ρύθμιση του διακομιστή σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor redirigió a un dominio diferente. Comprueba la configuración de tu servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a redirigé vers un autre domaine. Vérifiez la configuration de votre serveur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha reindirizzato a un dominio diverso. Controlla la configurazione del server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバが別のドメインにリダイレクトしました。サーバ設定を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器重定向到了不同的域名。请检查你的服务器配置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器重新導向到了不同的網域。請檢查你的伺服器組態。"
          }
        }
      }
    },
    "The server returned an API-level error.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat einen Fehler auf API-Ebene zurückgegeben."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής επέστρεψε ένα σφάλμα σε επίπεδο API."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor devolvió un error a nivel de API."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a renvoyé une erreur au niveau de l'API."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha restituito un errore a livello di API."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバがAPIレベルのエラーを返しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器返回了 API 级别的错误。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器傳回了 API 層級的錯誤。"
          }
        }
      }
    },
    "The server returned an unexpected error (HTTP %lld).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat einen unerwarteten Fehler zurückgegeben (HTTP %lld)."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής επέστρεψε ένα μη αναμενόμενο σφάλμα (HTTP %lld)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor devolvió un error inesperado (HTTP %lld)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a renvoyé une erreur inattendue (HTTP %lld)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha restituito un errore imprevisto (HTTP %lld)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバが予期しないエラーを返しました (HTTP %lld)。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器返回了意外错误 (HTTP %lld)。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器傳回了未預期的錯誤 (HTTP %lld)。"
          }
        }
      }
    },
    "The server returned an unexpected response.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat eine unerwartete Antwort zurückgegeben."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής επέστρεψε μια μη αναμενόμενη απάντηση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor devolvió una respuesta inesperada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a renvoyé une réponse inattendue."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha restituito una risposta imprevista."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバが予期しない応答を返しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器返回了意外响应。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器傳回了未預期的回應。"
          }
        }
      }
    },
    "The server took too long to respond. Check your network and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Server hat zu lange für eine Antwort gebraucht. Netzwerk prüfen und erneut versuchen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο διακομιστής άργησε πολύ να απαντήσει. Ελέγξτε το δίκτυό σας και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor tardó demasiado en responder. Comprueba tu red e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur a mis trop de temps à répondre. Vérifiez votre réseau et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server ha impiegato troppo tempo a rispondere. Controlla la rete e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サーバの応答に時間がかかりすぎました。ネットワークを確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器响应时间过长。请检查你的网络后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器回應時間過長。請檢查你的網路後再試一次。"
          }
        }
      }
    },
    "The server's TLS certificate could not be verified. Check your server's SSL configuration.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das TLS-Zertifikat des Servers konnte nicht überprüft werden. SSL-Konfiguration des Servers prüfen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν ήταν δυνατή η επαλήθευση του πιστοποιητικού TLS του διακομιστή. Ελέγξτε τη ρύθμιση SSL του διακομιστή σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar el certificado TLS del servidor. Comprueba la configuración SSL de tu servidor."
