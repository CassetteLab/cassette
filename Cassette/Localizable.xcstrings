    "Your changes are saved and will sync when your server is reachable.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Änderungen sind gespeichert und werden synchronisiert, sobald der Server erreichbar ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι αλλαγές σας αποθηκεύτηκαν και θα συγχρονιστούν όταν ο διακομιστής σας είναι προσβάσιμος."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus cambios se han guardado y se sincronizarán cuando tu servidor esté accesible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos modifications sont enregistrées et se synchroniseront lorsque votre serveur sera accessible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue modifiche sono salvate e verranno sincronizzate quando il tuo server sarà raggiungibile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更は保存され、サーバに接続できるようになると同期されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的更改已存储，将在你的服务器可访问时同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的變更已儲存，並會在你的伺服器可連線時同步。"
          }
        }
      }
    },
    "Your library appears to be empty.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Mediathek scheint leer zu sein."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η βιβλιοθήκη σας φαίνεται να είναι κενή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu biblioteca parece estar vacía."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre bibliothèque semble vide."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua libreria sembra vuota."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリは空のようです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的音乐库似乎是空的。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的資料庫似乎是空的。"
          }
        }
      }
    },
    "Your library is too small for Smart Shuffle. Try downloading more music or playing some tracks first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Mediathek ist zu klein für Smart Shuffle. Zuerst mehr Musik herunterladen oder einige Titel abspielen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η βιβλιοθήκη σας είναι πολύ μικρή για Smart Shuffle. Δοκιμάστε να λάβετε περισσότερη μουσική ή να αναπαράγετε πρώτα μερικά κομμάτια."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu biblioteca es demasiado pequeña para Smart Shuffle. Prueba a descargar más música o a reproducir algunas pistas primero."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre bibliothèque est trop petite pour Smart Shuffle. Essayez de télécharger plus de musique ou de lire quelques pistes d'abord."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua libreria è troppo piccola per Smart Shuffle. Prova prima a scaricare più musica o a riprodurre alcuni brani."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリがSmart Shuffleには小さすぎます。まずは音楽をもっとダウンロードするか、いくつかトラックを再生してみてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的音乐库太小，无法使用 Smart Shuffle。请先尝试下载更多音乐或播放一些曲目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的資料庫太小，無法使用 Smart Shuffle。請試著先下載更多音樂或播放一些曲目。"
          }
        }
      }
    },
    "Your library is waiting.\nTime to press play.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Mediathek wartet.\nZeit für Play."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η βιβλιοθήκη σας περιμένει.\nΏρα να πατήσετε play."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu biblioteca te espera.\nEs hora de darle a reproducir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre bibliothèque vous attend.\nIl est temps d'appuyer sur lecture."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La tua libreria ti aspetta.\nÈ ora di premere play."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ライブラリが待っています。\n再生ボタンを押しましょう。"
          }
        },
