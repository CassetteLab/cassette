    "Songs, albums, and artists you favorite will appear here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Als Favorit markierte Titel, Alben und Künstler erscheinen hier."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα τραγούδια, τα άλμπουμ και οι καλλιτέχνες που προσθέτετε στα αγαπημένα θα εμφανίζονται εδώ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las canciones, álbumes y artistas que marques como favoritos aparecerán aquí."
