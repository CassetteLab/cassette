    "Listen up — we'll keep track of your activity.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aufgepasst — wir behalten deine Aktivität im Blick."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ακούστε προσεκτικά — θα παρακολουθούμε τη δραστηριότητά σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atención: llevaremos el registro de tu actividad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Écoutez — nous suivrons votre activité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ascolta — terremo traccia della tua attività."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "準備はいいですか — あなたのアクティビティを記録します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "听好了 — 我们会记录你的活动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "注意囉——我們會記錄你的活動。"
          }
        }
      }
    },
