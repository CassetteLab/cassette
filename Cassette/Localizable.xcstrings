    },
    "This removes the playlist everywhere, including any downloaded copy.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt die Playlist überall, einschließlich heruntergeladener Kopien."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό αφαιρεί τη λίστα παντού, συμπεριλαμβανομένου κάθε ληφθέντος αντιγράφου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto quita la lista de todas partes, incluida cualquier copia descargada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela retire la liste de lecture partout, y compris toute copie téléchargée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove la playlist ovunque, inclusa qualsiasi copia scaricata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードしたコピーを含め、プレイリストをすべての場所から削除します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从所有位置移除该播放列表，包括任何已下载的副本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會在所有位置移除此播放列表，包含任何已下載的副本。"
          }
        }
      }
    },
    "This removes the playlist from your server. You can keep the files downloaded on this device, or remove them too. This cannot be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt die Playlist vom Server. Die heruntergeladenen Dateien können auf diesem Gerät behalten oder ebenfalls entfernt werden. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό αφαιρεί τη λίστα από τον διακομιστή σας. Μπορείτε να διατηρήσετε τα ληφθέντα αρχεία σε αυτήν τη συσκευή ή να τα αφαιρέσετε κι αυτά. Αυτό δεν μπορεί να αναιρεθεί."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto quita la lista de tu servidor. Puedes conservar los archivos descargados en este dispositivo o quitarlos también. Esto no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela retire la liste de lecture de votre serveur. Vous pouvez conserver les fichiers téléchargés sur cet appareil, ou les retirer aussi. Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove la playlist dal tuo server. Puoi mantenere i file scaricati su questo dispositivo o rimuoverli anch'essi. Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレイリストをサーバから削除します。このデバイスにダウンロードしたファイルは残すことも、一緒に削除することもできます。この操作は取り消せません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从你的服务器上移除该播放列表。你可以保留此设备上已下载的文件，也可以一并移除。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會從你的伺服器移除此播放列表。你可以保留下載在此裝置上的檔案，或一併移除。此操作無法復原。"
          }
        }
      }
    },
