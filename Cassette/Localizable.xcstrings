    "Stream your library from your own server.\nNo subscriptions. No big tech.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die eigene Mediathek vom eigenen Server streamen.\nKeine Abos. Keine Big-Tech-Konzerne."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάντε streaming τη βιβλιοθήκη σας από τον δικό σας διακομιστή.\nΧωρίς συνδρομές. Χωρίς μεγάλες εταιρείες τεχνολογίας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproduce en streaming tu biblioteca desde tu propio servidor.\nSin suscripciones. Sin grandes tecnológicas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Diffusez votre bibliothèque depuis votre propre serveur.\nAucun abonnement. Aucune grande tech."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riproduci in streaming la tua libreria dal tuo server.\nNessun abbonamento. Nessun colosso tech."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自分のサーバからライブラリをストリーミング。\nサブスク不要。大手テックにも依存しません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从你自己的服务器流播你的音乐库。\n无需订阅。远离科技巨头。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從你自己的伺服器串流你的資料庫。\n無需訂閱。不靠科技巨頭。"
          }
        }
      }
    },
