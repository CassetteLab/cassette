    "Cassette uses your system appearance setting. Per-app theme override is planned for a future release.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette verwendet die Erscheinungsbild-Einstellung des Systems. Ein app-eigenes Design ist für eine zukünftige Version geplant."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Cassette χρησιμοποιεί τη ρύθμιση εμφάνισης του συστήματός σας. Η παράκαμψη θέματος ανά εφαρμογή σχεδιάζεται για μελλοντική έκδοση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette usa el ajuste de apariencia del sistema. La personalización del tema por app está prevista para una versión futura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette utilise le réglage d'apparence de votre système. Un thème propre à l'app est prévu pour une future version."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette utilizza l'impostazione dell'aspetto del sistema. La personalizzazione del tema per singola app è prevista in una versione futura."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassetteはシステムの外観設定を使用します。アプリごとのテーマ設定は今後のリリースで対応予定です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette 使用你的系统外观设置。单独的应用主题设置计划在未来版本中推出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette 使用你的系統外觀設定。個別 App 主題覆寫功能預計於未來版本推出。"
          }
        }
      }
    },
