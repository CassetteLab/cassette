    "A client configuration error prevented connecting.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Fehler in der Client-Konfiguration hat die Verbindung verhindert."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένα σφάλμα ρύθμισης του πελάτη εμπόδισε τη σύνδεση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un error de configuración del cliente impidió la conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une erreur de configuration du client a empêché la connexion."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un errore di configurazione del client ha impedito la connessione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クライアント設定エラーのため接続できませんでした。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "客户端配置错误，无法连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用戶端組態錯誤，無法連線。"
          }
        }
      }
    },
    "A network error occurred. Please check your connection and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Netzwerkfehler ist aufgetreten. Bitte Verbindung prüfen und erneut versuchen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Παρουσιάστηκε σφάλμα δικτύου. Ελέγξτε τη σύνδεσή σας και δοκιμάστε ξανά."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se produjo un error de red. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une erreur réseau s'est produite. Vérifiez votre connexion et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si è verificato un errore di rete. Controlla la connessione e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワークエラーが発生しました。接続を確認してもう一度お試しください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发生网络错误。请检查网络连接后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "發生網路錯誤。請檢查你的連線後再試一次。"
          }
        }
      }
    },
