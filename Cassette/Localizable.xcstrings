    "No downloaded albums available. Download albums while online to listen offline.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine heruntergeladenen Alben verfügbar. Alben online herunterladen, um offline zu hören."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχουν διαθέσιμα ληφθέντα άλμπουμ. Λάβετε άλμπουμ ενώ είστε συνδεδεμένοι για να τα ακούτε εκτός σύνδεσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay álbumes descargados. Descarga álbumes con conexión para escucharlos sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun album téléchargé disponible. Téléchargez des albums en ligne pour les écouter hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun album scaricato disponibile. Scarica album quando sei online per ascoltarli offline."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロード済みのアルバムはありません。オフラインで聴くには、オンライン中にアルバムをダウンロードしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有可用的已下载专辑。请在联网时下载专辑以便离线收听。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有可用的已下載專輯。請在連線時下載專輯以便離線聆聽。"
          }
        }
      }
    },
    "No downloaded content.": {
