    "Keep your recent tracks ready instantly,\neven on a slow connection.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Letzte Titel sofort bereithalten,\nauch bei langsamer Verbindung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κρατήστε τα πρόσφατα κομμάτια σας άμεσα έτοιμα,\nακόμη και σε αργή σύνδεση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ten tus pistas recientes listas al instante,\nincluso con una conexión lenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez vos pistes récentes prêtes instantanément,\nmême avec une connexion lente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni i tuoi brani recenti pronti all'istante,\nanche con una connessione lenta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "低速な接続でも、最近のトラックを\nすぐに再生できるように準備します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即使在网络较慢时，也能即时准备好你最近的曲目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "讓你最近的曲目即時就緒，\n即使在緩慢的連線下也一樣。"
          }
        }
      }
    },
