    "iOS blocked the connection — use HTTPS or add an ATS exception in the app configuration.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS hat die Verbindung blockiert — HTTPS verwenden oder eine ATS-Ausnahme in der App-Konfiguration hinzufügen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το iOS απέκλεισε τη σύνδεση — χρησιμοποιήστε HTTPS ή προσθέστε μια εξαίρεση ATS στη ρύθμιση της εφαρμογής."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS bloqueó la conexión: usa HTTPS o añade una excepción de ATS en la configuración de la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS a bloqué la connexion — utilisez HTTPS ou ajoutez une exception ATS dans la configuration de l'app."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ha bloccato la connessione — usa HTTPS o aggiungi un'eccezione ATS nella configurazione dell'app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOSが接続をブロックしました — HTTPSを使用するか、アプリ設定でATS例外を追加してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 阻止了此连接 — 请使用 HTTPS 或在应用配置中添加 ATS 例外。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 已封鎖此連線——請使用 HTTPS，或在 App 組態中加入 ATS 例外。"
          }
        }
      }
    },
