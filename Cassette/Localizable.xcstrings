    "Your token will be removed and scrobbling disabled. You can reconnect anytime.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Token wird entfernt und Scrobbling deaktiviert. Du kannst dich jederzeit erneut verbinden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το token σας θα αφαιρεθεί και το scrobbling θα απενεργοποιηθεί. Μπορείτε να επανασυνδεθείτε ανά πάσα στιγμή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se quitará tu token y se desactivará el scrobbling. Puedes volver a conectarte en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre token sera retiré et le scrobbling désactivé. Vous pouvez vous reconnecter à tout moment."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo token verrà rimosso e lo scrobbling disattivato. Puoi riconnetterti in qualsiasi momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トークンが削除され、スクロブルが無効になります。いつでも再接続できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 token 将被移除，scrobbling 将被禁用。你可以随时重新连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 token 將被移除，並停用記錄播放。你隨時都能重新連線。"
          }
        }
      }
    },
    "Your unsaved changes will be lost.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine nicht gesicherten Änderungen gehen verloren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι μη αποθηκευμένες αλλαγές σας θα χαθούν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus cambios sin guardar se perderán."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos modifications non enregistrées seront perdues."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue modifiche non salvate andranno perse."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存されていない変更は失われます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你未存储的更改将会丢失。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你未儲存的變更將會遺失。"
          }
        }
      }
    },
    "Your username will be removed. You can reconnect anytime.": {
