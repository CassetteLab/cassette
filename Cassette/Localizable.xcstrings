    "'%@' is not downloaded and device is offline.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ ist nicht heruntergeladen und das Gerät ist offline."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το '%@' δεν έχει ληφθεί και η συσκευή είναι εκτός σύνδεσης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' no está descargado y el dispositivo está sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » n'est pas téléchargé et l'appareil est hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "'%@' non è scaricato e il dispositivo è offline."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」はダウンロードされておらず、デバイスはオフラインです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”尚未下载，且设备已离线。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」尚未下載，且裝置目前離線。"
          }
        }
      }
    },
    "\"%@\" is already in \"%@\". Add it again?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "\"%1$@\" is already in \"%2$@\". Add it again?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ ist bereits in „%@“. Erneut hinzufügen?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το «%@» υπάρχει ήδη στη «%@». Προσθήκη ξανά;"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» ya está en «%@». ¿Añadirlo de nuevo?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » est déjà dans « %@ ». L'ajouter à nouveau ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" è già in \"%@\". Aggiungerlo di nuovo?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」はすでに「%@」に含まれています。もう一度追加しますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”已在“%@”中。要再次添加吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」已經在「%@」中。要再次加入嗎？"
          }
        }
      }
    },
