    "Albums and playlists you download will appear here": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heruntergeladene Alben und Playlists erscheinen hier"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα άλμπουμ και οι λίστες που λαμβάνετε θα εμφανίζονται εδώ"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los álbumes y listas que descargues aparecerán aquí"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les albums et listes de lecture que vous téléchargez apparaîtront ici"
          }
