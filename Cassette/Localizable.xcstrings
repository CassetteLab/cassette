    "Unencrypted connection — make sure you are on a trusted network.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverschlüsselte Verbindung — sicherstellen, dass ein vertrauenswürdiges Netzwerk verwendet wird."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
