    "Tracks you add to the queue appear here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Titel, die zur Warteschlange hinzugefügt werden, erscheinen hier."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα κομμάτια που προσθέτετε στην ουρά εμφανίζονται εδώ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las pistas que añadas a la cola aparecen aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les pistes que vous ajoutez à la file d'attente apparaissent ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I brani che aggiungi alla coda appaiono qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キューに追加したトラックがここに表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你添加到队列的曲目将显示在此处。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你加入待播清單的曲目會顯示在這裡。"
          }
        }
      }
    },
    "Try a different search term.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einen anderen Suchbegriff versuchen."
          }
        },
