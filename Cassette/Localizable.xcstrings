    "Authentication failed — wrong username or password.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifizierung fehlgeschlagen — falscher Benutzername oder falsches Passwort."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η ταυτοποίηση απέτυχε — λάθος όνομα χρήστη ή κωδικός."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de autenticación: usuario o contraseña incorrectos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'authentification — nom d'utilisateur ou mot de passe incorrect."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Autenticazione non riuscita — nome utente o password errati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証に失敗しました — ユーザ名またはパスワードが違います。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证失败 — 用户名或密码错误。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "驗證失敗——使用者名稱或密碼錯誤。"
          }
        }
