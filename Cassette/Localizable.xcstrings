            "state": "translated",
            "value": "ダウンロードしたアルバムとプレイリストがここに表示されます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你下载的专辑和播放列表将显示在此处"
          }
