    "Optional headers sent with every request — useful for Cloudflare Access or other reverse-proxy authentication.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale Header, die mit jeder Anfrage gesendet werden — nützlich für Cloudflare Access oder andere Reverse-Proxy-Authentifizierung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προαιρετικές κεφαλίδες που αποστέλλονται με κάθε αίτημα — χρήσιμες για το Cloudflare Access ή άλλη ταυτοποίηση μέσω reverse-proxy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cabeceras opcionales enviadas con cada solicitud: útiles para Cloudflare Access u otra autenticación de proxy inverso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En-têtes facultatifs envoyés à chaque requête — utiles pour Cloudflare Access ou d'autres authentifications par reverse proxy."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Intestazioni opzionali inviate con ogni richiesta — utili per Cloudflare Access o altre autenticazioni tramite reverse proxy."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのリクエストに送信されるオプションのヘッダ — Cloudflare Accessやその他のリバースプロキシ認証に便利です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随每个请求发送的可选请求头 — 适用于 Cloudflare Access 或其他反向代理身份验证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隨每個請求傳送的選用標頭——適用於 Cloudflare Access 或其他反向代理驗證。"
          }
        }
      }
    },
