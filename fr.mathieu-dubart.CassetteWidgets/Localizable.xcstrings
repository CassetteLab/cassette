    "Open Cassette to get started": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassette öffnen, um zu beginnen"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ανοίξτε το Cassette για να ξεκινήσετε"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Cassette para empezar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez Cassette pour commencer"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Cassette per iniziare"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassetteを開いて始めましょう"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开 Cassette 即可开始"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟 Cassette 即可開始"
          }
        }
      }
    },
    "Pause": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause"
          }
        },
        "el": {
