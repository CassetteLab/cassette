    "Play / Pause": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiedergabe / Pause"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αναπαραγωγή / Παύση"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reproducir / Pausar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture / Pause"
          }
        },
        "it": {
          "stringUnit": {
