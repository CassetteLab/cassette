          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "暫停"
          }
        }
      }
    },
    "Pin albums or playlists in Cassette": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alben oder Playlists in Cassette anheften"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Καρφιτσώστε άλμπουμ ή λίστες στο Cassette"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fija álbumes o listas en Cassette"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Épinglez des albums ou des listes de lecture dans Cassette"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fissa album o playlist in Cassette"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cassetteでアルバムやプレイリストをピン留め"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Cassette 中固定专辑或播放列表"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Cassette 中釘選專輯或播放列表"
          }
        }
      }
    },
    "Pinned Items": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Angeheftete Objekte"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Καρφιτσωμένα στοιχεία"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elementos fijados"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éléments épinglés"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elementi fissati"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピン留めした項目"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已固定的项目"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已釘選的項目"
          }
        }
      }
    },
