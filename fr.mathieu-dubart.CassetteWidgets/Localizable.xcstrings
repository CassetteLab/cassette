            "value": "Pause"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausa"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一時停止"
          }
        },
        "zh-Hans": {
          "stringUnit": {
