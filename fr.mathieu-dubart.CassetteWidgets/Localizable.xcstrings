    "Quickly access your pinned items.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schneller Zugriff auf angeheftete Objekte."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Γρήγορη πρόσβαση στα καρφιτσωμένα στοιχεία σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accede rápidamente a tus elementos fijados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accédez rapidement à vos éléments épinglés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedi rapidamente ai tuoi elementi fissati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピン留めした項目にすばやくアクセスできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速访问你已固定的项目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快速存取你已釘選的項目。"
          }
        }
