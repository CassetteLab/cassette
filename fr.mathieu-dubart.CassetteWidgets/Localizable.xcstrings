{
  "sourceLanguage": "en",
  "strings": {
    "Displays the currently playing track.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigt den aktuell wiedergegebenen Titel an."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εμφανίζει το κομμάτι που αναπαράγεται τώρα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra la pista que se está reproduciendo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche la piste en cours de lecture."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra il brano attualmente in riproduzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在再生中のトラックを表示します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示当前正在播放的曲目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "顯示目前正在播放的曲目。"
          }
        }
      }
    },
